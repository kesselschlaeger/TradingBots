mport asyncio, threading, time
from live.health import HealthState
from core.config import load_config
from dashboard.app import create_app

cfg = load_config("configs/botti.yaml")
hs = HealthState()

# Fake-Daten befüllen
symbols = {"AAPL":"WAIT_BREAKOUT","NVDA":"GAP_BLOCK","SPY":"SIGNAL",
           "QQQ":"WAIT_ORB","MSFT":"TREND_BLOCK","TSLA":"MIT_BLOCK"}
for sym, code in symbols.items():
    hs.set_symbol_status("orb", sym, code, f"Test-Detail für {sym}")

import uvicorn
app = create_app(cfg, health_state=hs)
uvicorn.run(app, port=8080)